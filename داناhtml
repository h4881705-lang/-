<script>
// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
let busy=false, chatEnabled=false, currentMode='general';
let recognition=null, isRecording=false;
let currentChatMessages=[];
const ta=document.getElementById('uinput');

// ═══════════════════════════════════════════
// BANNED WORDS (safety filter)
// ═══════════════════════════════════════════
const BANNED=[
  // فحش فارسی
  'کیر','کس','کون','جنده','فاحشه','لاشی','مادرجنده','پدرجنده','ننه‌جنده','بیناموس','حرومزاده','گاییدن','کردن','گاییده','کسکش','کونی','اوناموس',
  'آشغال','خفه','گمشو',
  // انگلیسی
  'fuck','shit','bitch','nigger','nigga','whore','cunt','asshole','bastard','cock','pussy',
  // محتوای خطرناک
  'بمب','انفجار','ترور','کشتار','خودکشی','مواد مخدر','هروئین','شیشه','ساخت سلاح'
];
function hasBanned(msg){
  const low=msg.toLowerCase();
  return BANNED.some(w=>low.includes(w.toLowerCase()));
}

// ═══════════════════════════════════════════
// GREETINGS
// ═══════════════════════════════════════════
const GREET_RX=[
  /^سلام/,/^درود/,/^خوبی/,/^حالت/,/^چطوری/,/^چطور هستی/,/^هستی\b/,
  /^صبح بخیر/,/^عصر بخیر/,/^شب بخیر/,/^وقت بخیر/,/^hi\b/i,/^hello\b/i,/^hey\b/i,/^خداحافظ/,/^ممنون/,/^مرسی/,/^تشکر/
];
const GREET_RESP={
  greet:['👋 سلام! خوشحالم که اینجایی. دانا ۴.۰ آماده‌ست — چطور کمکت کنم؟','✨ سلام گرم! حالت خوبه؟ بپرس تا کمک کنم 😊','🌟 سلام! دانا در خدمته. چه موضوعی رو بررسی کنیم؟'],
  bye:['🌟 خداحافظ! هر وقت نیاز داشتی برگرد 😊','✨ موفق باشی! مراقب خودت باش 🙏'],
  thanks:['🤝 خواهش می‌کنم! خوشحالم که کمک کردم.','💜 لطف داری! هر سوال دیگه‌ای داشتی بپرس.']
};
function classifyGreet(msg){
  const t=msg.trim();
  // exact bye
  if(/^(خداحافظ|خدانگهدار|بای|bye|goodbye)[\s!.،]*$/i.test(t)) return 'bye';
  // exact thanks
  if(/^(ممنون|مرسی|تشکر|سپاس|ممنونم|متشکرم|thank you|thanks)[\s!.،]*$/i.test(t)) return 'thanks';
  // greet: ONLY if the message starts with a greeting word AND has no question content after it
  // (avoids "سلام ایران چیست" being treated as greeting)
  const startsWithGreet=GREET_RX.some(r=>r.test(t));
  if(startsWithGreet){
    // if there's meaningful content after the greeting word, don't classify as greeting
    const stripped=t.replace(/^(سلام|درود|hi|hello|hey|صبح بخیر|عصر بخیر|شب بخیر|وقت بخیر)[\s,،!]*/i,'').trim();
    if(stripped.length>4) return null; // has a real question after greeting
    return 'greet';
  }
  return null;
}
function rnd(arr){return arr[Math.floor(Math.random()*arr.length)]}

// ═══════════════════════════════════════════
// WIKIPEDIA API (with CORS proxy fallback)
// ═══════════════════════════════════════════
async function wikiSearch(query, lang='fa'){
  const base=`https://${lang}.wikipedia.org/w/api.php`;
  const controller=new AbortController();
  const tid=setTimeout(()=>controller.abort(),9000);
  try{
    const sr=await fetch(`${base}?action=query&list=search&srsearch=${encodeURIComponent(query)}&format=json&origin=*&srlimit=2`,{signal:controller.signal}).then(r=>r.json());
    clearTimeout(tid);
    const page=sr.query?.search?.[0];
    if(!page) return null;
    const controller2=new AbortController();
    const tid2=setTimeout(()=>controller2.abort(),9000);
    const cr=await fetch(`${base}?action=query&prop=extracts&exintro=true&explaintext=true&pageids=${page.pageid}&format=json&origin=*`,{signal:controller2.signal}).then(r=>r.json());
    clearTimeout(tid2);
    const ex=cr.query?.pages?.[page.pageid]?.extract;
    if(ex&&ex.trim().length>80){
      return{title:page.title,content:ex.substring(0,1600),url:`https://${lang}.wikipedia.org/wiki/${encodeURIComponent(page.title)}`,source:lang==='fa'?'ویکی‌پدیای فارسی':'Wikipedia (EN)'};
    }
  }catch(e){}
  return null;
}

// ═══════════════════════════════════════════
// DUCKDUCKGO INSTANT ANSWER
// ═══════════════════════════════════════════
async function ddgSearch(query){
  const controller=new AbortController();
  setTimeout(()=>controller.abort(),8000);
  try{
    const d=await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&no_html=1&skip_disambig=1`,{signal:controller.signal}).then(r=>r.json());
    const ans=d.AbstractText||d.Answer;
    if(ans&&ans.length>60){
      return{title:d.Heading||query,content:ans.substring(0,1000),url:d.AbstractURL||'https://duckduckgo.com',source:'DuckDuckGo'};
    }
    // Try related topics
    if(d.RelatedTopics&&d.RelatedTopics.length>0){
      const topics=d.RelatedTopics.filter(t=>t.Text).slice(0,4).map(t=>t.Text).join('\n\n');
      if(topics.length>80) return{title:query,content:topics,url:'https://duckduckgo.com',source:'DuckDuckGo'};
    }
  }catch(e){}
  return null;
}

// ═══════════════════════════════════════════
// OPEN-METEO (weather for Tehran as demo)
// ═══════════════════════════════════════════
async function getWeather(city){
  // Simple geocode for major Iranian cities
  const cities={تهران:{lat:35.69,lon:51.39},مشهد:{lat:36.29,lon:59.61},اصفهان:{lat:32.66,lon:51.68},شیراز:{lat:29.59,lon:52.58},تبریز:{lat:38.07,lon:46.29}};
  const c=cities[city]||cities['تهران'];
  try{
    const r=await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${c.lat}&longitude=${c.lon}&current=temperature_2m,relative_humidity_2m,wind_speed_10m,weather_code&timezone=Asia/Tehran`).then(r=>r.json());
    const cur=r.current;
    const wmap={0:'آفتابی ☀️',1:'عمدتاً آفتابی 🌤',2:'نیمه ابری ⛅',3:'ابری 🌥',45:'مه‌آلود 🌫',48:'مه‌آلود 🌫',51:'نم‌نم باران 🌦',61:'باران 🌧',80:'رگبار 🌧',95:'رعد و برق ⛈',99:'طوفان ⛈'};
    const wdesc=wmap[cur.weather_code]||'نامشخص';
    return{title:`آب و هوای ${city}`,content:`**دما:** ${cur.temperature_2m}°C\n**وضعیت:** ${wdesc}\n**رطوبت:** ${cur.relative_humidity_2m}%\n**سرعت باد:** ${cur.wind_speed_10m} km/h`,url:'https://open-meteo.com',source:'Open-Meteo'};
  }catch(e){}
  return null;
}

// ═══════════════════════════════════════════
// MAIN RESPONSE ENGINE
// ═══════════════════════════════════════════
async function getResponse(msg, mode){
  // Weather detection
  const weatherCities=['تهران','مشهد','اصفهان','شیراز','تبریز','کرج','اهواز'];
  if(/آب و هوا|هوا|دما|درجه|باران|برف/.test(msg)){
    const city=weatherCities.find(c=>msg.includes(c))||'تهران';
    const wr=await getWeather(city);
    if(wr) return{text:`### ${wr.title}\n\n${wr.content}`,sources:[wr]};
  }

  // Run all searches in parallel
  const [fa, en, ddg] = await Promise.allSettled([
    wikiSearch(msg,'fa'),
    wikiSearch(msg,'en'),
    ddgSearch(msg)
  ]);

  const faR=fa.status==='fulfilled'?fa.value:null;
  const enR=en.status==='fulfilled'?en.value:null;
  const ddgR=ddg.status==='fulfilled'?ddg.value:null;

  if(mode==='ziyarat'){
    const best=faR||enR||ddgR;
    if(best) return{text:`🕋 ### ${best.title}\n\n${best.content}\n\n> *برای متن کامل به مفاتیح الجنان مراجعه کنید.*`,sources:[best]};
    return{text:`📿 ### ${msg}\n\nبرای یافتن متن دقیق، به **مفاتیح الجنان** مراجعه فرمایید.\n\n**اعمال پربرکت:**\n- 🌟 دعای فرج\n- 📿 زیارت عاشورا\n- 🤲 دعای کمیل\n- ✨ تسبیح حضرت زهرا (س)`,sources:[]};
  }

  if(mode==='business'){
    const best=ddgR||faR||enR;
    if(best) return{text:`💼 ### ${best.title}\n\n${best.content}`,sources:[best]};
    return{text:`💡 ### راهنمای کسب‌وکار دیجیتال\n\n- **فروش آنلاین** محصولات پرطرفدار\n- **تولید محتوا** و بازاریابی شبکه‌های اجتماعی\n- **مشاوره تخصصی** آنلاین\n- **آموزش مجازی** مهارت‌های دیجیتال\n\n> سوال خود را دقیق‌تر بپرسید.`,sources:[]};
  }

  // General: prefer FA wiki, fallback EN, fallback DDG
  const best=faR||ddgR||enR;
  if(best) return{text:`### ${best.title}\n\n${best.content}`,sources:[best]};

  return{text:`🔍 **"${msg}"** در ویکی‌پدیا و منابع معتبر یافت نشد.\n\n**پیشنهادات:**\n- کلیدواژه‌های ساده‌تر استفاده کنید (مثلاً «ایران» به جای «تاریخ کامل ایران»)\n- سوال را به فارسی ساده بنویسید\n- حالت مناسب (زیارتی/کسب‌وکار) را انتخاب کنید`,sources:[]};
}

// ═══════════════════════════════════════════
// SPEECH RECOGNITION
// ═══════════════════════════════════════════
function initSpeech(){
  const SpeechRecognition=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SpeechRecognition){
    document.getElementById('mic-tip').textContent='مرورگر شما از گفتار پشتیبانی نمی‌کند';
    return;
  }
  recognition=new SpeechRecognition();
  recognition.lang='fa-IR';
  recognition.continuous=false;
  recognition.interimResults=true;
  recognition.maxAlternatives=1;

  recognition.onstart=()=>{
    isRecording=true;
    document.getElementById('mic-btn').classList.add('active');
    document.getElementById('sdot').classList.add('rec');
    document.getElementById('stxt').textContent='در حال ضبط... صحبت کنید';
    document.getElementById('mic-tip').textContent='کلیک کنید تا متوقف شود';
  };
  recognition.onresult=(e)=>{
    let interim='', final='';
    for(let i=e.resultIndex;i<e.results.length;i++){
      if(e.results[i].isFinal) final+=e.results[i][0].transcript;
      else interim+=e.results[i][0].transcript;
    }
    ta.value=final||interim;
    ta.style.height='auto';
    ta.style.height=Math.min(ta.scrollHeight,110)+'px';
  };
  recognition.onerror=(e)=>{
    stopRecording();
    if(e.error==='not-allowed') addMsg('err','❌ دسترسی به میکروفون رد شد. لطفاً در تنظیمات مرورگر اجازه دهید.');
    else if(e.error==='no-speech') addMsg('system','🎙 صدایی شنیده نشد. دوباره امتحان کنید.');
  };
  recognition.onend=()=>{ stopRecording(); if(ta.value.trim()) sendMessage(); };

  const micBtn=document.getElementById('mic-btn');
  micBtn.disabled=false;
  micBtn.addEventListener('click',()=>{
    if(!chatEnabled) return;
    if(isRecording){ recognition.stop(); }
    else{ try{ recognition.start(); }catch(e){} }
  });
}

function stopRecording(){
  isRecording=false;
  document.getElementById('mic-btn').classList.remove('active');
  document.getElementById('sdot').classList.remove('rec');
  document.getElementById('stxt').textContent='آماده پاسخگویی';
  document.getElementById('mic-tip').textContent='کلیک کنید و صحبت کنید...';
}

// ═══════════════════════════════════════════
// UI HELPERS
// ═══════════════════════════════════════════
function fmtBubble(text, sources=[]){
  let html=DOMPurify.sanitize(marked.parse(text));
  if(sources.length>0){
    const links=sources.filter(s=>s.url).map(s=>`<a href="${s.url}" target="_blank" rel="noopener" class="src-chip">📚 ${s.source}</a>`).join('');
    html+=`<div class="src-row">${links}</div>`;
  }
  if(currentMode==='ziyarat'){
    html+=`<button class="card-btn" onclick="makeCard(this)">🖼️ ساخت کارت دعا</button>`;
  }
  return html;
}

function addMsg(role, content, sources=[]){
  const msgs=document.getElementById('messages');
  const wel=document.getElementById('welcome');
  if(wel) wel.style.display='none';

  const row=document.createElement('div');
  row.className='mrow '+role;

  if(role==='user'||role==='dana'){
    const av=document.createElement('div');
    av.className='mav';
    av.innerHTML=role==='dana'?'<span>✦</span>':'👤';
    row.appendChild(av);
  }

  const bub=document.createElement('div');
  bub.className='bubble';
  if(role==='dana') bub.innerHTML=fmtBubble(content,sources);
  else if(role==='user') bub.textContent=content;
  else bub.innerHTML=DOMPurify.sanitize(content);

  row.appendChild(bub);
  if(role==='system'||role==='err') row.style.justifyContent='center';
  msgs.appendChild(row);
  msgs.scrollTop=msgs.scrollHeight;

  if(typeof gsap!=='undefined'){
    gsap.fromTo(row,{opacity:0,y:13},{opacity:1,y:0,duration:.36,ease:'power3.out'});
  }

  // store in current chat
  if(role==='user'||role==='dana'){
    currentChatMessages.push({role,content,sources,ts:Date.now()});
  }
  return row;
}

let tcnt=0;
function addTyping(){
  const id='t-'+(++tcnt);
  const msgs=document.getElementById('messages');
  const row=document.createElement('div');
  row.className='mrow dana'; row.id=id;
  row.innerHTML='<div class="mav"><span>✦</span></div><div class="bubble"><div class="typing-bub"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div></div>';
  msgs.appendChild(row);
  msgs.scrollTop=msgs.scrollHeight;
  return id;
}
function remTyping(id){ document.getElementById(id)?.remove(); }

function setBusy(s){
  busy=s;
  document.getElementById('sbtn').disabled=s;
  const dot=document.getElementById('sdot'), txt=document.getElementById('stxt');
  if(s){ dot.classList.add('busy'); txt.textContent='در حال جستجو...'; }
  else{ dot.classList.remove('busy'); txt.textContent='آماده پاسخگویی'; }
}

// ═══════════════════════════════════════════
// SEND
// ═══════════════════════════════════════════
async function sendMessage(txt){
  const msg=(txt||ta.value).trim();
  if(!msg||busy||!chatEnabled) return;

  // Safety filter
  if(hasBanned(msg)){
    ta.value=''; ta.style.height='auto';
    addMsg('err','🚫 پیام شما حاوی محتوای نامناسب است. لطفاً از کلمات مؤدبانه استفاده کنید.');
    return;
  }

  ta.value=''; ta.style.height='auto';
  setBusy(true);
  addMsg('user',msg);

  const gc=classifyGreet(msg);
  if(gc){
    addMsg('dana',rnd(GREET_RESP[gc]),[]);
    setBusy(false);
    return;
  }

  const tid=addTyping();
  try{
    const res=await getResponse(msg,currentMode);
    remTyping(tid);
    addMsg('dana',res.text,res.sources||[]);
  }catch(e){
    remTyping(tid);
    addMsg('err','❌ خطا در ارتباط با منابع. اینترنت را بررسی کنید.');
  }
  setBusy(false);
}

function insertQ(q){
  if(!chatEnabled) return;
  ta.value=q; ta.focus();
  ta.style.height='auto';
  ta.style.height=Math.min(ta.scrollHeight,110)+'px';
}

function setModeAndAsk(mode,q){
  if(!chatEnabled) return;
  currentMode=mode;
  document.querySelectorAll('.mbt').forEach(b=>b.classList.toggle('active',b.dataset.mode===mode));
  sendMessage(q);
}

// ═══════════════════════════════════════════
// CHAT HISTORY (localStorage)
// ═══════════════════════════════════════════
function getHistory(){
  try{ return JSON.parse(localStorage.getItem('dana_history')||'[]'); }
  catch(e){ return []; }
}
function saveHistory(arr){
  try{ localStorage.setItem('dana_history',JSON.stringify(arr)); }catch(e){}
}

function saveCurrentChat(){
  if(currentChatMessages.length===0){ addMsg('system','💡 هنوز پیامی برای ذخیره وجود ندارد.'); return; }
  const hist=getHistory();
  const firstUser=currentChatMessages.find(m=>m.role==='user');
  const title=firstUser?firstUser.content.substring(0,40):'چت بدون عنوان';
  hist.unshift({id:Date.now(),title,messages:currentChatMessages,date:new Date().toLocaleDateString('fa-IR')});
  if(hist.length>30) hist.splice(30);
  saveHistory(hist);
  updateHistCount();
  addMsg('system','✅ چت ذخیره شد.');
}

function loadChat(id){
  const hist=getHistory();
  const chat=hist.find(c=>c.id===id);
  if(!chat) return;
  toggleHistory();
  // Clear messages
  const msgs=document.getElementById('messages');
  msgs.innerHTML='';
  currentChatMessages=[];
  // Replay
  chat.messages.forEach(m=>{
    if(m.role==='user'){
      const row=document.createElement('div');
      row.className='mrow user';
      const av=document.createElement('div'); av.className='mav'; av.textContent='👤';
      const bub=document.createElement('div'); bub.className='bubble'; bub.textContent=m.content;
      row.appendChild(av); row.appendChild(bub);
      msgs.appendChild(row);
    } else if(m.role==='dana'){
      const row=document.createElement('div');
      row.className='mrow dana';
      const av=document.createElement('div'); av.className='mav'; av.innerHTML='<span>✦</span>';
      const bub=document.createElement('div'); bub.className='bubble';
      bub.innerHTML=fmtBubble(m.content,m.sources||[]);
      row.appendChild(av); row.appendChild(bub);
      msgs.appendChild(row);
    }
  });
  msgs.scrollTop=msgs.scrollHeight;
  currentChatMessages=[...chat.messages];
}

function deleteChat(id,e){
  e.stopPropagation();
  const hist=getHistory().filter(c=>c.id!==id);
  saveHistory(hist);
  renderHistory();
  updateHistCount();
}

function clearAllHistory(){
  if(!confirm('همه تاریخچه پاک شود؟')) return;
  saveHistory([]);
  renderHistory();
  updateHistCount();
}

function renderHistory(){
  const list=document.getElementById('hlist');
  const hist=getHistory();
  if(hist.length===0){
    list.innerHTML='<div class="hempty">📭 هنوز چتی ذخیره نشده<br><small>با دکمه 💾 چت‌های خود را ذخیره کنید</small></div>';
    return;
  }
  list.innerHTML=hist.map(c=>`
    <div class="hitem" onclick="loadChat(${c.id})">
      <button class="hitem-del" onclick="deleteChat(${c.id},event)">🗑</button>
      <div class="hitem-title">${DOMPurify.sanitize(c.title)}</div>
      <div class="hitem-date">${c.date} — ${c.messages.length} پیام</div>
    </div>
  `).join('');
}

function updateHistCount(){
  const n=getHistory().length;
  const badge=document.getElementById('hist-count');
  badge.textContent=n;
  badge.style.display=n>0?'flex':'none';
}

function toggleHistory(){
  const panel=document.getElementById('hpanel');
  const bd=document.getElementById('hbackdrop');
  const open=panel.classList.toggle('open');
  bd.classList.toggle('visible',open);
  if(open) renderHistory();
}

