// CARD MODAL
// ═══════════════════════════════════════════
function makeCard(btn){
  const bub=btn.closest('.bubble');
  const raw=(bub?.innerText||'').replace(/ساخت کارت دعا/g,'').substring(0,280).trim();
  const modal=document.createElement('div');
  modal.className='moverlay';
  modal.innerHTML=`
    <div class="mbox">
      <div class="mhdr"><div class="micon">🕋</div><div class="mtitle"><h2>کارت دعا</h2><p>برای اشتراک‌گذاری</p></div></div>
      <div class="cprev" id="cprev"><p class="ctxt">${DOMPurify.sanitize(raw)}...</p></div>
      <button class="svbtn" id="svbtn">📸 ذخیره به عنوان تصویر</button>
      <button class="clbtn" onclick="this.closest('.moverlay').remove()">بستن</button>
    </div>`;
  document.body.appendChild(modal);
  document.getElementById('svbtn').onclick=async()=>{
    const el=document.getElementById('cprev');
    const canvas=await html2canvas(el,{scale:2,backgroundColor:'#1a0a2e',useCORS:true});
    const a=document.createElement('a'); a.download='dana-prayer.png'; a.href=canvas.toDataURL(); a.click();
  };
}

