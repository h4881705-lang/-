// ═══════════════════════════════════════════
// MODE BUTTONS
// ═══════════════════════════════════════════
document.querySelectorAll('.mbt').forEach(btn=>{
  btn.addEventListener('click',()=>{
    currentMode=btn.dataset.mode;
    document.querySelectorAll('.mbt').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    if(chatEnabled) addMsg('system',`🔄 حالت به ${btn.textContent.trim()} تغییر یافت`);
  });
});

// Textarea auto-resize + Enter
ta.addEventListener('input',()=>{
  ta.style.height='auto';
  ta.style.height=Math.min(ta.scrollHeight,110)+'px';
});
ta.addEventListener('keydown',e=>{
  if(e.key==='Enter'&&!e.shiftKey&&chatEnabled){ e.preventDefault(); sendMessage(); }
});

// ═══════════════════════════════════════════
// RULES MODAL
// ═══════════════════════════════════════════
function showRules(){
  const modal=document.createElement('div');
  modal.className='moverlay';
  modal.innerHTML=`
    <div class="mbox">
      <div class="mhdr"><div class="micon">📜</div><div class="mtitle"><h2>قوانین استفاده</h2><p>لطفاً مطالعه و تأیید کنید</p></div></div>
      <ul class="rlist">
        <li><span class="ri">🔍</span> پاسخ‌ها از ویکی‌پدیا، DuckDuckGo و Open-Meteo استخراج می‌شود</li>
        <li><span class="ri">⚠️</span> اطلاعات ممکن است کامل نباشند؛ همیشه منابع را تأیید کنید</li>
        <li><span class="ri">🚫</span> استفاده از الفاظ نامناسب، توهین‌آمیز یا مضر ممنوع است</li>
        <li><span class="ri">🎙️</span> قابلیت تبدیل گفتار به متن با وب‌اسپیچ فعال است</li>
        <li><span class="ri">💾</span> تاریخچه چت‌ها در مرورگر شما ذخیره می‌شود</li>
        <li><span class="ri">👤</span> مسئولیت استفاده از اطلاعات با کاربر است</li>
      </ul>
      <div class="arow" id="arow">
        <input type="checkbox" id="ack">
        <label for="ack">قوانین را خوانده‌ام و می‌پذیرم</label>
      </div>
      <button class="stbtn" id="stbtn" disabled>✨ شروع استفاده</button>
    </div>`;
  document.body.appendChild(modal);
  const cb=document.getElementById('ack'), sb=document.getElementById('stbtn');
  cb.addEventListener('change',()=>sb.disabled=!cb.checked);
  document.getElementById('arow').addEventListener('click',e=>{
    if(e.target!==cb){ cb.checked=!cb.checked; sb.disabled=!cb.checked; }
  });
  sb.addEventListener('click',()=>{
    modal.remove();
    chatEnabled=true;
    ta.disabled=false;
    document.getElementById('sbtn').disabled=false;
    document.getElementById('sdot').classList.remove('busy');
    document.getElementById('stxt').textContent='آماده پاسخگویی';
    initSpeech();
    updateHistCount();
    addMsg('system','✅ خوش آمدید! دانا ۴.۰ آماده‌ست. سلام بگو یا سوالت رو بپرس 😊');
    ta.focus();
  });
}

window.addEventListener('DOMContentLoaded', showRules);
</script>
