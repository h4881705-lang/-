<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>دانا ۴.۰ — دستیار هوشمند</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/dompurify/3.0.6/purify.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<style>
:root{
  --bg:#060610;--s1:rgba(255,255,255,.04);--s2:rgba(255,255,255,.07);--s3:rgba(255,255,255,.11);
  --b1:rgba(255,255,255,.08);--b2:rgba(255,255,255,.15);
  --p1:#a78bfa;--p2:#818cf8;--p3:#38bdf8;--g1:#34d399;--amber:#fbbf24;--red:#f87171;
  --tx:#f0f0ff;--txd:rgba(240,240,255,.5);--txdd:rgba(240,240,255,.25);
  --r:20px;--rsm:12px;--rxs:8px;
}
*{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%;background:var(--bg);color:var(--tx);font-family:'Vazirmatn',sans-serif;overflow:hidden}
.orb{position:fixed;border-radius:50%;filter:blur(90px);pointer-events:none;z-index:0}
.o1{width:550px;height:550px;background:radial-gradient(circle,rgba(167,139,250,.13) 0%,transparent 70%);top:-120px;right:-120px;animation:drift 20s ease-in-out infinite alternate}
.o2{width:420px;height:420px;background:radial-gradient(circle,rgba(56,189,248,.1) 0%,transparent 70%);bottom:-100px;left:-100px;animation:drift 25s ease-in-out infinite alternate-reverse}
.o3{width:300px;height:300px;background:radial-gradient(circle,rgba(52,211,153,.08) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);animation:porb 9s ease-in-out infinite}
@keyframes drift{from{transform:translate(0,0) scale(1)}to{transform:translate(45px,35px) scale(1.12)}}
@keyframes porb{0%,100%{opacity:.5;transform:translate(-50%,-50%) scale(1)}50%{opacity:1;transform:translate(-50%,-50%) scale(1.25)}}
@keyframes hspin{from{filter:hue-rotate(0deg)}to{filter:hue-rotate(360deg)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:.2;transform:scale(.85)}50%{opacity:1;transform:scale(1.1)}}
@keyframes pdot{0%,100%{opacity:1}50%{opacity:.35}}
@keyframes modalIn{from{opacity:0;transform:scale(.88) translateY(22px)}to{opacity:1;transform:none}}
@keyframes pulse-ring{0%{box-shadow:0 0 0 0 rgba(248,113,113,.5)}70%{box-shadow:0 0 0 10px rgba(248,113,113,0)}100%{box-shadow:0 0 0 0 rgba(248,113,113,0)}}
@keyframes mic-active{0%,100%{box-shadow:0 0 0 0 rgba(248,113,113,.6)}50%{box-shadow:0 0 0 8px rgba(248,113,113,.15)}}

#app{position:relative;z-index:1;height:100vh;display:grid;grid-template-rows:auto 1fr auto auto;max-width:820px;margin:0 auto}

/* HEADER */
header{display:flex;align-items:center;justify-content:space-between;padding:13px 20px;background:rgba(6,6,16,.85);backdrop-filter:blur(30px);border-bottom:1px solid var(--b1);position:relative;flex-shrink:0;gap:10px}
header::after{content:'';position:absolute;bottom:0;left:8%;right:8%;height:1px;background:linear-gradient(90deg,transparent,var(--p1),var(--p2),transparent);opacity:.4}
.brand{display:flex;align-items:center;gap:11px;flex-shrink:0}
.borb{width:40px;height:40px;border-radius:50%;background:conic-gradient(from 180deg,#a78bfa,#818cf8,#38bdf8,#34d399,#a78bfa);display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 0 18px rgba(167,139,250,.4);animation:hspin 10s linear infinite;position:relative}
.borb::before{content:'';position:absolute;inset:2px;border-radius:50%;background:var(--bg);z-index:0}
.borb span{position:relative;z-index:1}
.btext h1{font-size:.9rem;font-weight:700;letter-spacing:.04em}
.btext p{font-size:.6rem;color:var(--txd);margin-top:1px;font-weight:300}
.modes{display:flex;gap:4px;background:rgba(255,255,255,.04);border:1px solid var(--b1);padding:4px;border-radius:50px}
.mbt{border:none;background:transparent;padding:5px 12px;border-radius:50px;font-size:.66rem;color:var(--txd);cursor:pointer;font-family:'Vazirmatn',sans-serif;transition:.25s;white-space:nowrap}
.mbt.active{background:linear-gradient(135deg,var(--p1),var(--p2));color:#fff;box-shadow:0 0 14px rgba(167,139,250,.35)}
.mbt:not(.active):hover{background:var(--s2);color:var(--tx)}
.hacts{display:flex;gap:6px;flex-shrink:0}
.ibt{width:34px;height:34px;border-radius:var(--rxs);border:1px solid var(--b1);background:var(--s1);color:var(--txd);cursor:pointer;font-size:13px;transition:.2s;display:flex;align-items:center;justify-content:center;position:relative}
.ibt:hover{background:var(--s2);border-color:var(--b2);color:var(--tx)}
.ibt-badge{position:absolute;top:-5px;left:-5px;min-width:16px;height:16px;background:var(--p1);border-radius:8px;font-size:.55rem;color:#fff;display:flex;align-items:center;justify-content:center;padding:0 3px;font-family:'Vazirmatn',sans-serif}

/* MESSAGES */
#messages{overflow-y:auto;padding:22px 16px;display:flex;flex-direction:column;gap:18px;scroll-behavior:smooth;min-height:0}
#messages::-webkit-scrollbar{width:3px}
#messages::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1);border-radius:3px}

/* WELCOME */
#welcome{display:flex;flex-direction:column;align-items:center;padding:28px 16px;text-align:center;gap:16px}
.worb{width:72px;height:72px;border-radius:50%;background:conic-gradient(from 0deg,#a78bfa,#38bdf8,#34d399,#fbbf24,#a78bfa);display:flex;align-items:center;justify-content:center;font-size:32px;box-shadow:0 0 40px rgba(167,139,250,.3);animation:hspin 8s linear infinite;position:relative}
.worb::before{content:'';position:absolute;inset:3px;border-radius:50%;background:var(--bg)}
.worb span{position:relative;z-index:1}
#welcome h2{font-size:1.35rem;font-weight:800;background:linear-gradient(135deg,#a78bfa,#38bdf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
#welcome p{font-size:.8rem;color:var(--txd);max-width:300px;line-height:1.6}
.qgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;width:100%;max-width:400px}
.qcard{background:var(--s1);border:1px solid var(--b1);padding:13px 8px;border-radius:var(--r);cursor:pointer;transition:.25s;font-size:.7rem;color:var(--txd);display:flex;flex-direction:column;align-items:center;gap:5px}
.qcard:hover{background:var(--s2);border-color:var(--b2);color:var(--tx);transform:translateY(-2px);box-shadow:0 8px 20px rgba(0,0,0,.3)}

/* MSG */
.mrow{display:flex;gap:10px;align-items:flex-end}
.mrow.user{flex-direction:row-reverse}
.mav{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0}
.mrow.dana .mav{background:conic-gradient(from 180deg,#a78bfa,#818cf8,#38bdf8,#a78bfa);box-shadow:0 0 12px rgba(167,139,250,.35);animation:hspin 10s linear infinite;position:relative}
.mrow.dana .mav::before{content:'';position:absolute;inset:2px;border-radius:50%;background:#0d0d1e}
.mrow.dana .mav span{position:relative;z-index:1}
.mrow.user .mav{background:var(--s3);border:1px solid var(--b2)}
.bubble{max-width:78%;padding:13px 15px;line-height:1.85;font-size:.83rem;position:relative;border-radius:var(--r)}
.mrow.user .bubble{background:linear-gradient(135deg,rgba(167,139,250,.82),rgba(129,140,248,.82));border-radius:var(--r) var(--r) 6px var(--r);color:#fff;backdrop-filter:blur(20px);box-shadow:0 4px 20px rgba(167,139,250,.22)}
.mrow.dana .bubble{background:rgba(255,255,255,.05);border:1px solid var(--b1);border-radius:var(--r) var(--r) var(--r) 6px;backdrop-filter:blur(20px);box-shadow:0 4px 24px rgba(0,0,0,.3)}
.mrow.system .bubble{background:rgba(251,191,36,.08);border:1px solid rgba(251,191,36,.2);font-size:.74rem;color:var(--amber);text-align:center;max-width:100%}
.mrow.err .bubble{background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);font-size:.77rem;color:var(--red)}
.bubble h1,.bubble h2,.bubble h3{color:var(--p1);margin:9px 0 5px;font-size:.88rem;font-weight:700}
.bubble strong{color:var(--p1)}
.bubble p{margin:5px 0}
.bubble ul,.bubble ol{margin:7px 0 7px 20px}
.bubble a{color:var(--p2)}
.bubble code{background:rgba(255,255,255,.08);padding:2px 6px;border-radius:4px;font-size:.79rem}
.bubble blockquote{border-right:3px solid var(--p1);padding:7px 11px;margin:7px 0;background:rgba(255,255,255,.04);border-radius:0 8px 8px 0;font-style:italic}
.src-row{margin-top:9px;padding-top:7px;border-top:1px solid var(--b1);display:flex;flex-wrap:wrap;gap:5px}
.src-chip{font-size:.59rem;padding:3px 9px;border-radius:20px;background:rgba(167,139,250,.1);border:1px solid rgba(167,139,250,.25);color:var(--p1);text-decoration:none;transition:.2s}
.src-chip:hover{background:rgba(167,139,250,.2)}
.card-btn{margin-top:9px;display:inline-flex;align-items:center;gap:5px;background:rgba(52,211,153,.1);border:1px solid rgba(52,211,153,.3);color:#34d399;padding:5px 13px;border-radius:20px;font-size:.68rem;cursor:pointer;font-family:'Vazirmatn',sans-serif;transition:.2s}
.card-btn:hover{background:rgba(52,211,153,.2)}
.typing-bub{display:flex;gap:6px;padding:5px 2px;align-items:center}
.dot{width:7px;height:7px;border-radius:50%;background:var(--p1);opacity:.5;animation:blink 1.2s ease-in-out infinite}
.dot:nth-child(2){animation-delay:.2s}.dot:nth-child(3){animation-delay:.4s}

/* SUGGESTIONS */
.sugs{display:flex;gap:7px;flex-wrap:nowrap;overflow-x:auto;padding:7px 16px;flex-shrink:0}
.sugs::-webkit-scrollbar{height:0}
.sbt{background:var(--s1);border:1px solid var(--b1);padding:6px 13px;border-radius:25px;font-size:.68rem;color:var(--txd);cursor:pointer;font-family:'Vazirmatn',sans-serif;transition:.2s;white-space:nowrap;flex-shrink:0}
.sbt:hover{background:var(--s2);color:var(--tx);border-color:var(--b2)}

/* INPUT */
#iarea{padding:9px 15px 15px;background:rgba(6,6,16,.88);backdrop-filter:blur(30px);border-top:1px solid var(--b1);flex-shrink:0}
#iarea::before{content:'';display:block;height:1px;margin-bottom:9px;background:linear-gradient(90deg,transparent,var(--p1),var(--p3),transparent);opacity:.18}
.ishell{display:flex;align-items:flex-end;gap:7px;background:rgba(255,255,255,.05);border:1px solid var(--b1);border-radius:var(--r);padding:9px 11px;transition:.2s}
.ishell:focus-within{border-color:rgba(167,139,250,.4);box-shadow:0 0 0 3px rgba(167,139,250,.08)}
#uinput{flex:1;background:none;border:none;outline:none;color:var(--tx);font-family:'Vazirmatn',sans-serif;font-size:.84rem;resize:none;max-height:110px;min-height:22px;line-height:1.5}
#uinput::placeholder{color:var(--txdd)}
.mic-wrap{position:relative;flex-shrink:0}
#mic-btn{width:38px;height:38px;border-radius:10px;border:1px solid var(--b1);background:var(--s1);color:var(--txd);font-size:16px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:.2s;flex-shrink:0}
#mic-btn.active{border-color:rgba(248,113,113,.6);background:rgba(248,113,113,.12);color:var(--red);animation:mic-active 1s ease infinite}
#mic-btn:hover:not(.active){background:var(--s2);color:var(--tx)}
#mic-btn:disabled{opacity:.35;cursor:not-allowed}
.mic-tip{position:absolute;bottom:calc(100% + 8px);right:0;background:rgba(12,12,28,.97);border:1px solid var(--b2);border-radius:10px;padding:6px 11px;font-size:.63rem;white-space:nowrap;color:var(--txd);opacity:0;transform:translateY(4px);transition:.2s;pointer-events:none;z-index:50;font-family:'Vazirmatn',sans-serif}
.mic-wrap:hover .mic-tip{opacity:1;transform:translateY(0)}
#sbtn{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--p1),var(--p2));border:none;cursor:pointer;color:white;font-size:15px;flex-shrink:0;transition:.2s;box-shadow:0 4px 14px rgba(167,139,250,.3);display:flex;align-items:center;justify-content:center}
#sbtn:hover:not(:disabled){transform:scale(1.07);box-shadow:0 6px 18px rgba(167,139,250,.45)}
#sbtn:disabled{opacity:.38;cursor:not-allowed;transform:none}
.ifooter{display:flex;justify-content:space-between;align-items:center;margin-top:6px;font-size:.6rem;color:var(--txdd);padding:0 2px}
.sdot{width:6px;height:6px;border-radius:50%;background:var(--g1);display:inline-block;margin-left:5px;box-shadow:0 0 7px rgba(52,211,153,.5);animation:pdot 2s ease infinite}
.sdot.busy{background:var(--amber);box-shadow:0 0 7px rgba(251,191,36,.5);animation:none}
.sdot.rec{background:var(--red);box-shadow:0 0 7px rgba(248,113,113,.6);animation:pdot .7s ease infinite}

/* MODAL */
.moverlay{position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,.9);backdrop-filter:blur(22px);display:flex;align-items:center;justify-content:center;padding:18px}
.mbox{background:rgba(10,10,24,.97);border:1px solid var(--b2);border-radius:26px;max-width:480px;width:100%;padding:26px;box-shadow:0 30px 80px rgba(0,0,0,.65);animation:modalIn .32s cubic-bezier(.34,1.56,.64,1)}
.mhdr{display:flex;align-items:center;gap:11px;margin-bottom:18px}
.micon{width:46px;height:46px;border-radius:13px;background:linear-gradient(135deg,var(--p1),var(--p2));display:flex;align-items:center;justify-content:center;font-size:21px;box-shadow:0 0 18px rgba(167,139,250,.35);flex-shrink:0}
.mtitle h2{font-size:1.05rem;font-weight:700}
.mtitle p{font-size:.68rem;color:var(--txd);margin-top:2px}
.rlist{list-style:none;margin:0 0 18px;display:flex;flex-direction:column;gap:9px}
.rlist li{display:flex;align-items:flex-start;gap:9px;padding:10px 13px;border-radius:11px;background:var(--s1);border:1px solid var(--b1);font-size:.76rem;line-height:1.6}
.ri{font-size:.95rem;flex-shrink:0;margin-top:1px}
.arow{display:flex;align-items:center;gap:10px;padding:11px 13px;border-radius:11px;background:rgba(167,139,250,.07);border:1px solid rgba(167,139,250,.2);cursor:pointer;margin-bottom:15px;transition:.2s}
.arow:hover{background:rgba(167,139,250,.12)}
.arow input{accent-color:var(--p1);width:16px;height:16px;cursor:pointer}
.arow label{font-size:.76rem;cursor:pointer;flex:1}
.stbtn{width:100%;padding:13px;background:linear-gradient(135deg,var(--p1),var(--p2));border:none;border-radius:13px;color:white;font-weight:700;font-size:.88rem;cursor:pointer;font-family:'Vazirmatn',sans-serif;box-shadow:0 8px 22px rgba(167,139,250,.32);transition:.2s}
.stbtn:hover:not(:disabled){box-shadow:0 12px 30px rgba(167,139,250,.45);transform:translateY(-1px)}
.stbtn:disabled{opacity:.32;cursor:not-allowed;transform:none}

/* HISTORY PANEL */
.hpanel{position:fixed;top:0;right:0;width:280px;height:100vh;background:rgba(8,8,20,.97);border-left:1px solid var(--b2);z-index:1500;transform:translateX(100%);transition:transform .32s cubic-bezier(.4,0,.2,1);backdrop-filter:blur(20px);display:flex;flex-direction:column}
.hpanel.open{transform:translateX(0)}
.hphdr{padding:18px 16px 14px;border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.hphdr h3{font-size:.88rem;font-weight:700}
.hclose{background:none;border:none;color:var(--txd);font-size:18px;cursor:pointer;width:28px;height:28px;display:flex;align-items:center;justify-content:center;border-radius:6px;transition:.2s}
.hclose:hover{background:var(--s2);color:var(--tx)}
.hlist{flex:1;overflow-y:auto;padding:10px 12px;display:flex;flex-direction:column;gap:7px}
.hlist::-webkit-scrollbar{width:3px}
.hlist::-webkit-scrollbar-thumb{background:rgba(255,255,255,.1)}
.hitem{background:var(--s1);border:1px solid var(--b1);border-radius:11px;padding:10px 12px;cursor:pointer;transition:.2s}
.hitem:hover{background:var(--s2);border-color:var(--b2)}
.hitem-title{font-size:.74rem;font-weight:600;color:var(--tx);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.hitem-date{font-size:.6rem;color:var(--txdd)}
.hitem-del{float:left;background:none;border:none;color:var(--txdd);cursor:pointer;font-size:12px;padding:0 2px;transition:.2s;font-family:'Vazirmatn',sans-serif}
.hitem-del:hover{color:var(--red)}
.hempty{text-align:center;padding:30px 16px;color:var(--txdd);font-size:.78rem;line-height:1.7}
.hfooter{padding:12px 16px;border-top:1px solid var(--b1);flex-shrink:0}
.hclear-btn{width:100%;padding:9px;background:rgba(248,113,113,.08);border:1px solid rgba(248,113,113,.2);border-radius:10px;color:var(--red);font-size:.74rem;cursor:pointer;font-family:'Vazirmatn',sans-serif;transition:.2s}
.hclear-btn:hover{background:rgba(248,113,113,.15)}
.hpanel-backdrop{position:fixed;inset:0;z-index:1400;background:rgba(0,0,0,.4);opacity:0;pointer-events:none;transition:.3s}
.hpanel-backdrop.visible{opacity:1;pointer-events:auto}

/* CARD */
.cprev{background:linear-gradient(145deg,#1a0a2e,#0a1a2e);border-radius:18px;padding:22px;margin-bottom:14px;text-align:center;border:1px solid rgba(167,139,250,.3);min-height:150px;display:flex;align-items:center;justify-content:center}
.ctxt{color:#e0d4ff;font-size:.84rem;line-height:1.9}
.svbtn{width:100%;padding:11px;background:linear-gradient(135deg,var(--g1),#059669);border:none;border-radius:11px;color:white;font-weight:600;cursor:pointer;font-family:'Vazirmatn',sans-serif;font-size:.83rem;margin-bottom:7px;transition:.2s}
.svbtn:hover{opacity:.9}
.clbtn{width:100%;padding:9px;background:var(--s2);border:1px solid var(--b1);border-radius:11px;color:var(--txd);cursor:pointer;font-family:'Vazirmatn',sans-serif;font-size:.78rem;transition:.2s}
.clbtn:hover{background:var(--s3);color:var(--tx)}

@media(max-width:540px){
  .modes{display:none}
  .qgrid{grid-template-columns:1fr 1fr}
  .bubble{max-width:88%}
  .hpanel{width:85vw}
}
</style>
</head>
<body>
<div class="orb o1"></div><div class="orb o2"></div><div class="orb o3"></div>

<!-- History Panel -->
<div class="hpanel-backdrop" id="hbackdrop" onclick="toggleHistory()"></div>
<div class="hpanel" id="hpanel">
  <div class="hphdr">
    <h3>📂 تاریخچه چت‌ها</h3>
    <button class="hclose" onclick="toggleHistory()">✕</button>
  </div>
  <div class="hlist" id="hlist"></div>
  <div class="hfooter">
    <button class="hclear-btn" onclick="clearAllHistory()">🗑 پاک کردن همه</button>
  </div>
</div>

<div id="app">
  <header>
    <div class="brand">
      <div class="borb"><span>✦</span></div>
      <div class="btext"><h1>دانا ۴.۰</h1><p>دستیار هوشمند با جستجوی واقعی</p></div>
    </div>
    <div class="modes" id="msel">
      <button class="mbt active" data-mode="general">🧠 عمومی</button>
      <button class="mbt" data-mode="ziyarat">🕋 زیارتی</button>
      <button class="mbt" data-mode="business">💼 کسب‌وکار</button>
    </div>
    <div class="hacts">
      <button class="ibt" id="hist-btn" onclick="toggleHistory()" title="تاریخچه چت‌ها">📂<span class="ibt-badge" id="hist-count" style="display:none">0</span></button>
      <button class="ibt" onclick="saveCurrentChat()" title="ذخیره چت فعلی">💾</button>
      <button class="ibt" onclick="clearChat()" title="چت جدید">✏️</button>
    </div>
  </header>

  <div id="messages">
    <div id="welcome">
      <div class="worb"><span>✦</span></div>
      <h2>دانا ۴.۰</h2>
      <p>جستجوی واقعی در ویکی‌پدیا و منابع معتبر — آماده پاسخگویی</p>
      <div class="qgrid">
        <div class="qcard" onclick="setModeAndAsk('general','هوش مصنوعی')"><span style="font-size:1.3rem">🧠</span><span>هوش مصنوعی</span></div>
        <div class="qcard" onclick="setModeAndAsk('ziyarat','دعای فرج')"><span style="font-size:1.3rem">🕋</span><span>دعای فرج</span></div>
        <div class="qcard" onclick="setModeAndAsk('business','استارتاپ')"><span style="font-size:1.3rem">💼</span><span>کسب‌وکار</span></div>
        <div class="qcard" onclick="setModeAndAsk('general','پایتون چیست')"><span style="font-size:1.3rem">🐍</span><span>پایتون</span></div>
        <div class="qcard" onclick="setModeAndAsk('ziyarat','تسبیح')"><span style="font-size:1.3rem">📿</span><span>تسبیحات</span></div>
        <div class="qcard" onclick="setModeAndAsk('business','بازاریابی')"><span style="font-size:1.3rem">📈</span><span>بازاریابی</span></div>
