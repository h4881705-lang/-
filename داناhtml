    <div class="ishell">
      <textarea id="uinput" placeholder="سوال خود را بپرسید..." rows="1" disabled></textarea>
      <div class="mic-wrap">
        <button id="mic-btn" title="تبدیل گفتار به متن" disabled>🎙️</button>
